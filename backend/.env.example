# Railway Environment Variables Template
# Copy these to your Railway project settings

# Django Settings
SECRET_KEY=your-super-secret-key-here-generate-a-new-one
DEBUG=False

# Railway will automatically provide DATABASE_URL for PostgreSQL
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Frontend Domain (without https://)
FRONTEND_DOMAIN=your-frontend-domain.vercel.app

# Custom Domain (optional)
# CUSTOM_DOMAIN=api.yourdomain.com

# Email Configuration (optional)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=no-reply@yourdomain.com

# JWT Settings (optional - defaults are set)
# JWT_ACCESS_TOKEN_LIFETIME=60
# JWT_REFRESH_TOKEN_LIFETIME=10080
